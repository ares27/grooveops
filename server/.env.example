# Backend (.env)
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/grooveops

# Firebase Admin SDK
# Option 1: Use service account JSON (place serviceAccountKey.json in server root)
# Option 2: Use environment variable with JSON
# FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","...":...}'
# You can get the service account key from:
# Firebase Console → Project Settings → Service Accounts → Generate Private Key

# ==========================================
# CLIENT & API URLS
# ==========================================
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api

# ==========================================
# EMAIL CONFIGURATION - REQUIRED for invitations
# ==========================================
# Choose ONE email provider below

# 🟢 Option 1: Gmail (✅ RECOMMENDED FOR TESTING)
# Setup:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Copy the 16-character password (without spaces) below
# 
EMAIL_PROVIDER=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=noreply@grooveops.com

# 🔵 Option 2: SendGrid (✅ RECOMMENDED FOR PRODUCTION)
# Setup:
#   1. Create SendGrid account: https://sendgrid.com
#   2. Create API key: https://app.sendgrid.com/settings/api_keys
#   3. Copy your SG.* API key below
#
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
# EMAIL_FROM=noreply@grooveops.com

# 🟡 Option 3: Generic SMTP (Mailgun, Postmark, etc.)
# Setup: Find SMTP details from your email service provider
#
# EMAIL_PROVIDER=smtp
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-username
# EMAIL_PASSWORD=your-password
# EMAIL_FROM=noreply@grooveops.com

# ==========================================
# CORS Configuration (optional)
# ==========================================
CORS_ORIGIN=http://localhost:5173

# ==========================================
# Optional Services (future use)
# ==========================================
# JWT_SECRET=your-jwt-secret-key
# REDIS_URL=redis://localhost:6379
